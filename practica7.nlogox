      <setup>setup</setup>
      <go>go</go>
      <runMetricsCondition>ticks mod 5000 = 0 ;;cada 5000 iteraciones</runMetricsCondition>
      <metrics>
        <metric>Psi</metric>
      </metrics>
      <constants>
        <enumeratedValueSet variable="c">
