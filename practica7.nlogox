<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.1" snapToGrid="true">
  <code><![CDATA[;;Cargamos la extensión de los colores
extensions [palette rnd]



;;Definimos primero las propiedades de las tortugas
;;la vecindad realizada va a ser la que resulte de las interaccione en cada iteración
;;w - valor de la similaridad relativa
turtles-own[Di Si vecindad_original vecindad_realizada w]


to setup 
  clear-all
  
  ;;El número de agentes del modelo va a estar dada por el tamaño de nuestro mundo
  ;;pues en cada celda de nuestra látice vamos a crear a un agente
  let num_agentes world-width * world-height
  create-turtles num_agentes [
    ;;para tener una lista de valores aleatorios entre 1 y m
    set Di n-values n [(random m) + 1]
    ;;para tener un valor aleatorio entre 1 y k
    set Si (random k) + 1
    ;;cambiamos el tamaño de los agentes
    set size 0.75
    ;;definimos las formas que pueden tomar
    let formas ["x" "circle" "triangle" "star" "square"]
    ;;si Si es 1 entonces vamos a tener x, si es dos circulitos y así sucesivamente
    ;;Las formas denotarán los partidos políticos
    set shape item (Si - 1) formas
  ]
  
  ;;debemos ordenar a los agentes como si estuvieran en una látices
  ;;foreach sólo acepta listas, pero el sort hace que acomodemos a las tortugas como si estuvieran en una
  ;;ordenamos también a los patches
  ;;vamos a iterar esas dos listas, por eso los paréntesis antes del foreach
  (foreach (sort turtles) (sort patches) [
    ;;cada elemento de la lista turtles es p y de los patches es p
    [t p] -> ask t [move-to p]
  ])
  
  ;;Aquí creamos los links entre los vecinos de la vecindad de Moore
  ask turtles[
    create-links-with (turtles-on neighbors) [
      set color black + 3
    ]
    ;;me retorna los agentes que son mis vecinos con las que está conectadas
    set vecindad_original link-neighbors
    ;;inicializamos el valor de vecindad realizada con el de vecindad original
    set vecindad_realizada vecindad_original
    colorear_agente
  ]
  
  reset-ticks
end

to colorear_agente
  let mi_color calcular_color Di
  let max_color calcular_color n-values n [m]
  set color palette:scale-gradient (palette:scheme-colors "Divergent" "Spectral" 11) mi_color 0 max_color
end

;;Para calcular las escalas de colores dependiendo de su similitud
to-report calcular_color [_Di]
  report sum (map [ l -> (item (l - 1) _Di) * (m ^ (l - 1)) / (m ^ n)] (range 1 (n + 1)) )
end

to go
  ask one-of turtles[
    ;;Para ver qué porción de vecinos vamos a reemplazar
    let num_reemplazar round (count vecindad_original * gamma)
    let vecindad_reemplazo n-of num_reemplazar other turtles
    let vecindad_no_reemplazo n-of (count vecindad_original - num_reemplazar) vecindad_original
    set vecindad_realizada (turtle-set vecindad_reemplazo vecindad_no_reemplazo)
    
    
    ;;visualización
    set pcolor white
    ask my-links [die]
    create-links-with vecindad_realizada [
      set color white
      set thickness 0.1
    ]
    ask vecindad_realizada [set pcolor gray]
    display
    
    ask my-links [die]
    create-links-with vecindad_original [
      set color black + 3
    ]
    ;;;;;;;
    
    ;;Seleccionar al agente con el que interactuo
    let influencer seleccionar_influencer
    ask influencer [set pcolor yellow]
    display
    
    copiar_atributo influencer
    colorear_agente
  ]
  
   ask patches [set pcolor black]
  
  tick
end

to copiar_atributo [mi_influencer]
  let indices_diff filter [l -> (item l Di) != (item l [Di] of mi_influencer)] range (length Di)
  if indices_diff != [] [
    let indice_reemplazar one-of indices_diff
    set Di replace-item indice_reemplazar Di (item indice_reemplazar [Di] of mi_influencer)
  ]
end

;;Calculo de la delta i,j superíndice s
to-report delta_S_ij [agente_i agente_j]
  ;;si es verdadero regresamos 1, sino 0
  report ifelse-value [Si] of agente_i = [Si] of agente_j [1] [0]
end

to-report delta_D_ijl [agente_i agente_j l]
  report ifelse-value [item (l - 1) Di] of agente_i  = [item (l - 1) Di] of agente_j [1] [0]
end

to-report delta_ij [agente_i agente_j]
  let suma_delta_D_ij sum (map [l -> delta_D_ijl agente_i agente_j l] (range 1 (n + 1)))
  report ((c * (delta_S_ij agente_i agente_j)) + suma_delta_D_ij) / (c + n)
end

to-report w_ij [agente_i agente_j]
  let deltas_h map [agente_k -> (delta_ij agente_i agente_k)^ h] sort [vecindad_realizada] of agente_i
  report ifelse-value (sum deltas_h != 0) [(delta_ij agente_i agente_j) ^ h / sum deltas_h] [0]
end

to-report seleccionar_influencer
  ;;vamos a calcular la similitud relativa
  ask vecindad_realizada[
    set w w_ij myself self
  ]
  report rnd:weighted-one-of vecindad_realizada [ w ]
end


to-report d_ij [agente_i agente_j]
  report sum (map [l ->  delta_D_ijl agente_i agente_j l] (range 1 (n + 1))) / n
  
end

to-report Q_same
  let Q []
  ask turtles [
    ask other turtles with [Si = [Si] of myself][
      set Q lput (d_ij myself self) Q
    ]
  ]
  report Q
end

to-report Q_diff
  let Q []
  ask turtles [
    ask other turtles with [Si != [Si] of myself][
      set Q lput (d_ij myself self) Q
    ]
  ]
  report Q
end

to-report Psi
  let Qs Q_same
  let Qd Q_diff
  report (sum Qs / length Qs) - (sum Qd / length Qd)
end













]]></code>
  <widgets>
    <view x="400" wrappingAllowedX="true" y="10" frameRate="30.0" minPycor="0" height="220" showTickCounter="true" patchSize="14.4" fontSize="10" wrappingAllowedY="true" width="220" tickCounterLabel="ticks" maxPycor="14" updateMode="1" maxPxcor="14" minPxcor="0"></view>
    <button x="10" y="10" height="40" disableUntilTicks="false" forever="false" kind="Observer" width="55">setup</button>
    <button x="10" y="55" height="40" disableUntilTicks="false" forever="true" kind="Observer" width="55">go</button>
    <slider x="75" step="1" y="35" max="10" width="215" display="n" height="50" min="1" direction="Horizontal" default="10.0" variable="n"></slider>
    <note x="70" y="85" backgroundDark="0" fontSize="12" width="260" markdown="false" height="20" textColorDark="-1" textColorLight="-16777216" backgroundLight="0">número de preferencias por cada atributo Di</note>
    <slider x="75" step="1" y="110" max="10" width="220" display="m" height="50" min="1" direction="Horizontal" default="10.0" variable="m"></slider>
    <note x="70" y="165" backgroundDark="0" fontSize="12" width="180" markdown="false" height="18" textColorDark="-1" textColorLight="-16777216" backgroundLight="0">número de grupos políticos Si</note>
    <slider x="75" step="1" y="190" max="5" width="225" display="k" height="50" min="1" direction="Horizontal" default="3.0" variable="k"></slider>
    <note x="70" y="245" backgroundDark="0" fontSize="12" width="200" markdown="false" height="20" textColorDark="-1" textColorLight="-16777216" backgroundLight="0">fracción de vecinos a reemplazar</note>
    <slider x="75" step="0.01" y="270" max="1" width="230" display="gamma" height="50" min="0" direction="Horizontal" default="1.0" variable="gamma"></slider>
    <note x="70" y="325" backgroundDark="0" fontSize="12" width="325" markdown="false" height="20" textColorDark="-1" textColorLight="-16777216" backgroundLight="0">peso que se le da a alguien con el mismo grupo político</note>
    <slider x="75" step="1" y="350" max="10" width="235" display="c" height="50" min="0" direction="Horizontal" default="4.0" variable="c"></slider>
    <note x="65" y="405" backgroundDark="0" fontSize="12" width="300" markdown="false" height="18" textColorDark="-1" textColorLight="-16777216" backgroundLight="0">peso que se le da alguien que es similar (homofilia)</note>
    <note x="65" y="10" backgroundDark="0" fontSize="12" width="210" markdown="false" height="18" textColorDark="-1" textColorLight="-16777216" backgroundLight="0">número de atributos dinámicos Di</note>
    <slider x="75" step="1" y="425" max="10" width="235" display="h" height="50" min="0" direction="Horizontal" default="8.0" variable="h"></slider>
    <plot x="395" autoPlotX="true" yMax="1.0" autoPlotY="true" yAxis="Psi" y="240" xMin="0.0" height="175" legend="false" xMax="10.0" yMin="0.0" width="230" xAxis="ticks" display="Psi">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="0" display="default" color="-16777216" legend="true">
        <setup></setup>
        <update>if ticks mod tiempo_graficar = 0 [plot Psi]</update>
      </pen>
    </plot>
    <input x="630" multiline="false" y="15" height="60" variable="tiempo_graficar" type="number" width="250">1000.0</input>
  </widgets>
